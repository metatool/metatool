{
  "Services": {
    "ScreenHintConfig": {
      "HintEncoder": {
        "HintKeys": "kjdflsahgionurvcwexmbpqtyz", // char[]
        "AdditionalSingleCodeKey": "JDFLAHGINREMBQTY1234567890" // char[]
      },
      "HintForeground": "#FFD700",
      //ARGB
      "HintSingleCharBackground": "#B80033CC",
      "HintTwoCharBackground": "#B8339933",
      "HintBackground": "#B8CC3333",
      "HintMatchedColor": "#9090A0"
    }
  },
  "Tools": {
    "Metatool.Tools.KeyMouse": {
      "KeyboardMousePackage": {
        // not work well, if click to change active window
        // need to just handle alt+tab switch
        "MouseFollowActiveWindow": false,
        "KeyMaps": {
          "GK + Q": "LButton",
          "GK + R": "RButton", // right click under mouse pointer
          // the keybord Apps key
          "GK + T": "Apps" // context menu, same as right click the text under keyboard cursor, or the control has keyboard focus
        },
        "Hotkeys": {
          "MouseToFocus": {
            // * behind the trigger key to mark down/up Event handled
            "Hotkey": "GK + G*",
            "Description": "Move Mouse To Active Control"
          },
          // we can also use ctrl+up or ctrl+down to scroll a component, but the component must support this hotkey.
          // most components in windows support this hotkey. but there is corner cases, i.e. the 'git changes viewer' vs vscode does not support it.
          "MouseScrollUp": {
            "Hotkey": "GK + W*",
            "Description": "Scroll Up with Mouse"
          },
          "MouseScrollDown": {
            "Hotkey": "GK + S*",
            "Description": "Scroll Down with Mouse"
          },
          "MouseDown": {
            "Hotkey": "GK + D*",
            "Description": "Move Mouse Down"
          },
          "MouseUp": {
            "Hotkey": "GK + E*",
            "Description": "Move Mouse Up"
          },
          "MouseLeft": {
            "Hotkey": "GK + A*",
            "Description": "Move Mouse Left"
          },
          "MouseRight": {
            "Hotkey": "GK + F*",
            "Description": "Move Mouse Right"
          },
          "MouseLeftClick": {
            "Hotkey": "GK + C*",
            "Description": "Mouse Left Click via Hint"
          },
          "MouseLeftClickAlt": {
            "Hotkey": "GK + Shift + C*",
            "Description": "Mouse Left Click via Hint with WPF Detector"
          },
          "MouseLeftClickLast": {
            "Hotkey": "GK + X*",
            "Description": "Mouse Left Click via Last Hint"
          },
          "ActivateWindowOnScreen00": {
            "Hotkey": "Tab + 1*",
            "Description": "Activate Top Window on Screen (0, 0)"
          },
          "ActivateWindowOnScreen01": {
            "Hotkey": "Tab + 2*",
            "Description": "Activate Top Window on Screen (0, 1)"
          },
          "ActivateWindowOnScreen10": {
            "Hotkey": "Tab + Q*",
            "Description": "Activate Top Window on Screen (1, 0)"
          }
        }
      }
    }
  }
}